<idea-plugin>
    <id>com.qoliber.indexblocker</id>
    <name>Index Blocker</name>
    <vendor email="jwinkler@qoliber.com" url="https://qoliber.com">Qoliber</vendor>

    <description><![CDATA[
        Globally exclude folders from indexing across all projects.<br/>
        Configure under <b>Settings &rarr; Tools &rarr; Index Blocker</b>.
        Supports exact folder names (<code>var</code>), prefix wildcards
        (<code>Test*</code>), and relative paths (<code>pub/static</code>).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            groupId="tools"
            id="com.qoliber.phpstorm.indexblocker.settings"
            displayName="Index Blocker"
            instance="com.qoliber.phpstorm.indexblocker.IndexBlockerConfigurable"/>

        <projectService
            serviceImplementation="com.qoliber.phpstorm.indexblocker.IndexBlockerRefresher"/>

        <directoryIndexExcludePolicy
            implementation="com.qoliber.phpstorm.indexblocker.IndexBlockerExcludePolicy"/>

        <vfs.asyncListener
            implementation="com.qoliber.phpstorm.indexblocker.IndexBlockerVfsListener"/>

        <applicationConfigurable
            groupId="tools"
            id="com.qoliber.indexblocker.cachehealth.settings"
            displayName="Cache Health"
            instance="com.qoliber.phpstorm.indexblocker.cachehealth.CacheHealthConfigurable"/>

        <notificationGroup id="Cache Health" displayType="BALLOON"/>
    </extensions>

    <applicationListeners>
        <listener
            class="com.qoliber.phpstorm.indexblocker.cachehealth.CacheHealthStartup"
            topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <actions>
        <action id="com.qoliber.indexblocker.cachehealth.Trim"
                class="com.qoliber.phpstorm.indexblocker.cachehealth.TrimCachesAction"
                text="Trim Caches"
                description="Delete safe-to-clear PhpStorm caches"/>
        <action id="com.qoliber.indexblocker.cachehealth.Invalidate"
                class="com.qoliber.phpstorm.indexblocker.cachehealth.InvalidateAndRestartAction"
                text="Invalidate Caches and Restart"
                description="Invalidate caches and restart the IDE"/>
        <action id="com.qoliber.indexblocker.cachehealth.Widget"
                class="com.qoliber.phpstorm.indexblocker.cachehealth.CacheHealthToolbarWidget"
                text="Cache Health">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
